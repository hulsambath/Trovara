# Secrets (plaintext) - NEVER commit
android/app/upload.jks
android/keystore.properties
android/app/google-services.json

# Per-flavor google-services (contain API keys)
android/app/src/*/google-services.json

# Firebase options - stubs with placeholders are committed for static analysis
# Real keys are injected at build time via CI or by running: scripts/flutterfire.sh
# After running flutterfire configure locally, restore stubs: git checkout lib/firebase_options/
ios/Firebase/
macos/Firebase/
**/GoogleService-Info.plist

lib/firebase_options/staging.dart
lib/firebase_options/prod.dart

# Config files with OAuth credentials
configs/trovara.json
configs/trovara_staging.json
configs/trovara_prod.json
configs/trovara_dev.json

# Ignore staging/prod google-services placed per flavor
android/app/src/staging/google-services.json
android/app/src/prod/google-services.json

# Ignore staging config with sensitive API keys
configs/trovara_staging.json



# Local credentials working dir
.local-credentials/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/
*.pem
# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/git commit -m "Close #48 Embedding model"

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

configs/trovara.json
configs/trovara_dev.json
configs/trovara_prod.json

# Cursor rules
.cursor/
ios/Flutter/DartDefines.xcconfig
