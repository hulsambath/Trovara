#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔍 Analyzing code changes for PR description...${NC}"

# Get the current branch name
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Function to get the base branch
get_base_branch() {
    if git show-ref --verify --quiet refs/heads/main; then
        echo "main"
    else
        echo "develop"
    fi
}

base_branch=$(get_base_branch)

# Get list of files changed
changed_files=$(git diff --name-status $base_branch..$current_branch)

# Function to analyze file changes
analyze_changes() {
    local file="$1"
    local change_type="$2"

    case $change_type in
        M) local status="Modified";;
        A) local status="Added";;
        D) local status="Deleted";;
        R) local status="Renamed";;
        *) local status="Changed";;
    esac

    if [[ -f "$file" ]]; then
        # Get file extension
        local ext="${file##*.}"

        case $ext in
            dart)
                # Analyze Dart files
                local class_changes=$(git diff $base_branch..$current_branch "$file" | grep '^[+-].*class' | wc -l)
                local function_changes=$(git diff $base_branch..$current_branch "$file" | grep '^[+-].*\b\(void\|Future\|String\|int\|bool\|double\|List\|Map\|Widget\)\b.*(.*)' | wc -l)
                local state_changes=$(git diff $base_branch..$current_branch "$file" | grep '^[+-].*\b\(State\|Provider\|ChangeNotifier\)\b' | wc -l)

                echo "  - $status \`$file\`"
                [[ $class_changes -gt 0 ]] && echo "    - Classes modified: $class_changes"
                [[ $function_changes -gt 0 ]] && echo "    - Functions/methods modified: $function_changes"
                [[ $state_changes -gt 0 ]] && echo "    - State management changes: $state_changes"
                ;;
            yaml|json)
                # Analyze configuration files
                echo "  - $status \`$file\` (Configuration)"
                ;;
            *)
                echo "  - $status \`$file\`"
                ;;
        esac
    fi
}

# Generate change summary
generate_summary() {
    local files_by_type=()

    # Categorize changes
    echo "## � Changes Summary"
    echo ""

    # UI Changes (views and widgets)
    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/\(views\|widgets\)/"; then
        echo "### 🎨 UI Changes"
        echo ""
        while IFS= read -r line; do
            local status=${line:0:1}
            local file=${line:2}
            if [[ $file =~ ^lib/(views|widgets)/ ]]; then
                analyze_changes "$file" "$status"
            fi
        done <<< "$changed_files"
        echo ""
    fi

    # Model Changes
    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/models/"; then
        echo "### 🔧 Model Changes"
        echo ""
        while IFS= read -r line; do
            local status=${line:0:1}
            local file=${line:2}
            if [[ $file =~ ^lib/models/ ]]; then
                analyze_changes "$file" "$status"
            fi
        done <<< "$changed_files"
        echo ""
    fi

    # Core Changes
    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/core/"; then
        echo "### ⚙️ Core Changes"
        echo ""
        while IFS= read -r line; do
            local status=${line:0:1}
            local file=${line:2}
            if [[ $file =~ ^lib/core/ ]]; then
                analyze_changes "$file" "$status"
            fi
        done <<< "$changed_files"
        echo ""
    fi

    # Test Changes
    if git diff --name-only $base_branch..$current_branch | grep -q "^test/"; then
        echo "### 🧪 Test Changes"
        echo ""
        while IFS= read -r line; do
            local status=${line:0:1}
            local file=${line:2}
            if [[ $file =~ ^test/ ]]; then
                analyze_changes "$file" "$status"
            fi
        done <<< "$changed_files"
        echo ""
    fi

    # Other Changes
    if git diff --name-only $base_branch..$current_branch | grep -qv "^lib/\|^test/"; then
        echo "### 📦 Other Changes"
        echo ""
        while IFS= read -r line; do
            local status=${line:0:1}
            local file=${line:2}
            if ! [[ $file =~ ^lib/ || $file =~ ^test/ ]]; then
                analyze_changes "$file" "$status"
            fi
        done <<< "$changed_files"
        echo ""
    fi

    # Impact Analysis
    echo "### 🎯 Impact Analysis"
    echo ""

    # Count total changes
    local total_files=$(git diff --name-only $base_branch..$current_branch | wc -l)
    local additions=$(git diff --stat $base_branch..$current_branch | tail -n 1 | grep -o '[0-9]\+ insertion' | grep -o '[0-9]\+')
    local deletions=$(git diff --stat $base_branch..$current_branch | tail -n 1 | grep -o '[0-9]\+ deletion' | grep -o '[0-9]\+')

    echo "- Total files changed: $total_files"
    [[ ! -z "$additions" ]] && echo "- Lines added: $additions"
    [[ ! -z "$deletions" ]] && echo "- Lines removed: $deletions"
    echo ""

    # Commits included
    echo "### 🔄 Commits Included"
    echo ""
    git log $base_branch..$current_branch --pretty=format:"- %s%n  %b" --reverse
    echo ""

    # Testing Notes
    echo "### 🧪 Testing Notes"
    echo ""
    echo "The following areas should be tested:"
    echo ""

    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/views/"; then
        echo "- [ ] UI functionality"
        echo "- [ ] Layout on different screen sizes"
    fi
    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/models/"; then
        echo "- [ ] Data persistence"
        echo "- [ ] Model validations"
    fi
    if git diff --name-only $base_branch..$current_branch | grep -q "^lib/core/"; then
        echo "- [ ] Core functionality"
        echo "- [ ] Error handling"
    fi
    echo "- [ ] Regression testing"
    echo ""
}

# Generate PR description
pr_description=$(generate_summary)

# Save PR description for reference
pr_desc_file=".git/LATEST_PR_DESCRIPTION"
echo "$pr_description" > "$pr_desc_file"

echo -e "${GREEN}✅ Change summary generated${NC}"
echo -e "${BLUE}📝 Saved to $pr_desc_file${NC}"

# If this is a feature branch, create/update PR
if [[ $current_branch =~ ^[0-9]+-.*$ ]]; then
    issue_number=$(echo $current_branch | cut -d'-' -f1)
    echo -e "${BLUE}🔄 Adding PR description as comment to issue #$issue_number...${NC}"

    # Add comment to the issue using the MCP API
    mcp github add-issue-comment \
        --owner "hulsambath" \
        --repo "notemyminds" \
        --issue_number "$issue_number" \
        --body "$pr_body"

    echo -e "${GREEN}✅ Comment added to issue #$issue_number${NC}"
fi
