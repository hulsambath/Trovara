# ============================================================
# .antigravityignore — Trovara (Flutter Note-Taking App)
# Keeps build artifacts, generated code, secrets, platform
# boilerplate, large binaries, and dependencies out of
# Antigravity's context window.
# ============================================================

# ── Git internals ─────────────────────────────────────────
**/.git/

# ── Build outputs ─────────────────────────────────────────
**/build/
**/.dart_tool/
**/.gradle/

# ── Flutter / Dart build metadata ─────────────────────────
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata

# ── Generated Dart code ──────────────────────────────────
**/*.g.dart
**/*.freezed.dart
**/*.config.dart
**/*.gr.dart
**/*.gen.dart
**/*.mocks.dart
**/*.reflectable.dart
lib/gen/assets.gen.dart
lib/gen/fonts.gen.dart
lib/objectbox.g.dart
lib/firebase_options/
lib/generated_plugin_registrant.dart

# ── Platform directories (rarely hand-authored) ──────────
android/
ios/
macos/
linux/
windows/
web/

# ── Dependencies ─────────────────────────────────────────
**/Pods/
**/.pub-cache/
**/.pub/
**/DerivedData/

# ── Lock files ───────────────────────────────────────────
pubspec.lock
**/Podfile.lock
**/Gemfile.lock

# ── Secrets & credentials ───────────────────────────────
**/*.jks
**/*.keystore
**/*.pem
**/*.p8
**/*.p12
**/key.properties
**/local.properties
**/.env
**/.env.*
**/google-services.json
**/GoogleService-Info*.plist
configs/trovara.json
configs/trovara_staging.json
configs/trovara_prod.json
configs/trovara_dev.json
upload_certificate.pem

# ── IDE / tooling internals ──────────────────────────────
**/.antigravity/
**/.cursor/
**/.claude/
**/.idea/
**/.vscode/
**/.fvm/
**/.code-review-graph/
**/.copilot/
**/.ruby-lsp/
.tool-versions

# ── Virtual environments ─────────────────────────────────
.venv/
.venv_icon/

# ── Test & coverage ──────────────────────────────────────
coverage/

# ── Logs & caches ────────────────────────────────────────
**/*.log
**/.cache/

# ── OS files ─────────────────────────────────────────────
**/.DS_Store
**/Thumbs.db
**/.Spotlight-V100
**/.Trashes

